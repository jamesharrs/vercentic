# client/.env.production
# API calls go direct to Railway — bypasses Vercel edge proxy entirely.
# api.vercentic.com can't be used while Vercel controls the nameservers
# (Vercel intercepts all subdomains before following CNAME to Railway).
# Direct Railway URL works identically and saves all edge requests.
VITE_API_URL=https://talentos-production-4045.up.railway.app
