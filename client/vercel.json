{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://talentos-production-4045.up.railway.app/api/:path*" },
    { "source": "/portal/:slug*", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
